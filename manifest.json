{
  "manifest_version": 3,
  "name": "FoodFlag",
  "version": "1.1",
  "description": "Scans Amazon product pages and flags potential allergens, synonyms and cross reactive ingredients",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.amazon.co.uk/*",
    "*://*.amazon.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.amazon.co.uk/*", "*://*.amazon.com/*"],
      "js": ["synonyms.js", "crossreactivity.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
